<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101418">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/browser_top_bar_bg"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Search engine favicon icon -->
        <ImageView
            android:id="@+id/imgSearchEngine"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/browser_icon_button_bg"
            android:padding="7dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_find" />

        <EditText
            android:id="@+id/textUrl"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search"
            android:hint="Search or type URL"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textColorHint="#8A93A2" />

        <ImageView
            android:id="@+id/btnBookmark"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/browser_icon_button_bg"
            android:padding="8dp"
            android:src="@drawable/star_outline"
            android:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/browser_icon_button_bg"
            android:padding="8dp"
            android:src="@drawable/menu"
            android:tint="#FFFFFF" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@drawable/browser_bottom_bar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <HorizontalScrollView
            android:id="@+id/tabScroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tabsContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/btnTabSwitcher"
            android:layout_width="42dp"
            android:layout_height="34dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/browser_icon_button_bg"
            android:gravity="center"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnNewTab"
            android:layout_width="36dp"
            android:layout_height="34dp"
            android:background="@drawable/browser_icon_button_bg"
            android:gravity="center"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressDrawable="@drawable/progress_bar"
        app:layout_constraintTop_toBottomOf="@id/tabBar" />

    <!-- Web Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintTop_toBottomOf="@id/progressBar">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


    <FrameLayout
        android:id="@+id/pluginSidePanelHost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="@drawable/browser_popup_bg"
        android:elevation="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintWidth_percent="0.50" />

    <!-- Fullscreen Video Container -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Find In Page Bar -->
    <LinearLayout
        android:id="@+id/findBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/browser_bottom_bar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <EditText
            android:id="@+id/findInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Find in page..."
            android:textColor="#FFF"
            android:textColorHint="#555" />
        <TextView
            android:id="@+id/findMatches"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888"
            android:layout_marginHorizontal="8dp"
            android:text="0/0" />
        <Button
            android:id="@+id/btnFindPrev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prev" />
        <Button
            android:id="@+id/btnFindNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next" />
        <ImageView
            android:id="@+id/btnFindClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/close"
            android:tint="#FFFFFF" />
    </LinearLayout>

    <!-- Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@drawable/browser_bottom_bar_bg"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/goBack"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="17dp"
            android:background="@drawable/browser_nav_button_bg"
            android:src="@drawable/arrow_left"
            android:tint="#888888"
            android:alpha="0.85" />

        <ImageView
            android:id="@+id/goHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="15dp"
            android:background="@drawable/browser_nav_button_bg"
            android:src="@drawable/home"
            android:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/goForward"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="17dp"
            android:background="@drawable/browser_nav_button_bg"
            android:src="@drawable/arrow_right"
            android:tint="#888888"
            android:alpha="0.85" />

        <ImageView
            android:id="@+id/btnConsole"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/browser_nav_button_bg"
            android:contentDescription="Show console"
            android:padding="16dp"
            android:src="@drawable/tool"
            android:tint="#7CC7FF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
